{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEC home page content",
  "type": "object",
  "required": ["hero", "about", "campusLife"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "hero": {
      "type": "array",
      "description": "Full-screen carousel slides at the very top of the home page.",
      "items": {
        "type": "object",
        "required": ["image", "title", "description"],
        "additionalProperties": false,
        "properties": {
          "image": {
            "allOf": [{ "$ref": "./_schema/asset-keys.json" }],
            "description": "Background image key (autocompletes from R2)."
          },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "about": {
      "type": "object",
      "description": "The 'About BEC' section: one image + the carousel of paragraphs.",
      "required": ["image", "established", "establishedLabel", "slides"],
      "additionalProperties": false,
      "properties": {
        "image": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }] },
        "established": { "type": "string", "description": "Big number shown on the image, e.g. \"1963\"." },
        "establishedLabel": { "type": "string" },
        "slides": {
          "type": "array",
          "description": "Each entry is one carousel slide; each slide is a list of paragraphs.",
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "campusLife": {
      "type": "array",
      "description": "The 'Student Life' feature cards near the bottom of the home page.",
      "items": {
        "type": "object",
        "required": ["image", "title", "description"],
        "additionalProperties": false,
        "properties": {
          "image": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "className": {
            "type": "string",
            "description": "Optional Tailwind grid span controlling the card size, e.g. \"md:col-span-2 md:row-span-2\"."
          }
        }
      }
    }
  }
}
