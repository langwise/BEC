{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEC governance / leadership content",
  "type": "object",
  "required": ["principal", "deans", "officers", "hods", "sangha", "bog"],
  "additionalProperties": false,
  "$defs": {
    "assetKey": {
      "allOf": [{ "$ref": "./_schema/asset-keys.json" }],
      "description": "Photo key (autocompletes from the assets uploaded to R2)."
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "principal": {
      "type": "object",
      "description": "The Principal / Member Secretary shown in the leadership banner.",
      "required": ["name", "role", "photo"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "photo": { "$ref": "#/$defs/assetKey" },
        "email": { "type": "string" }
      }
    },
    "deans": {
      "type": "array",
      "description": "Deans rendered in the #deans section.",
      "items": {
        "type": "object",
        "required": ["role"],
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string", "description": "Portfolio, e.g. \"Dean Academic\"." },
          "name": { "type": "string" },
          "photo": { "$ref": "#/$defs/assetKey" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "focus": { "type": "string", "description": "Short description of the portfolio." },
          "placeholder": { "type": "boolean", "description": "Set true while the person is unconfirmed; renders a 'to be updated' badge." },
          "verify": { "type": "boolean", "description": "Set true when the name/role mapping is a best-guess that a coordinator should confirm." }
        }
      }
    },
    "officers": {
      "type": "array",
      "description": "Other key institutional officers (Controller of Examinations, Librarian, etc.).",
      "items": {
        "type": "object",
        "required": ["role"],
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string" },
          "name": { "type": "string" },
          "photo": { "$ref": "#/$defs/assetKey" },
          "email": { "type": "string" },
          "focus": { "type": "string" },
          "placeholder": { "type": "boolean" },
          "verify": { "type": "boolean" }
        }
      }
    },
    "hods": {
      "type": "array",
      "description": "Heads of Department for the #hods directory.",
      "items": {
        "type": "object",
        "required": ["department"],
        "additionalProperties": false,
        "properties": {
          "department": { "type": "string" },
          "name": { "type": "string" },
          "title": { "type": "string" },
          "photo": { "$ref": "#/$defs/assetKey" },
          "email": { "type": "string" },
          "placeholder": { "type": "boolean", "description": "Set true (and omit name/photo) for departments whose HOD is not yet confirmed." }
        }
      }
    },
    "sangha": {
      "type": "object",
      "description": "B.V.V. Sangha (parent trust) leadership shown above the Board of Governors.",
      "required": ["groupPhoto", "members"],
      "additionalProperties": false,
      "properties": {
        "intro": { "type": "string" },
        "groupPhoto": { "$ref": "#/$defs/assetKey" },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "photo": { "$ref": "#/$defs/assetKey" },
              "verify": { "type": "boolean" }
            }
          }
        }
      }
    },
    "bogLastUpdated": { "type": "string" },
    "bog": {
      "type": "array",
      "description": "Board of Governors members for the #bog section.",
      "items": {
        "type": "object",
        "required": ["name", "role", "affiliation", "category"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "affiliation": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["chair", "sangha", "nominee", "industry", "academia", "faculty", "invitee", "government", "member-secretary", "students"]
          },
          "photo": { "$ref": "#/$defs/assetKey" }
        }
      }
    }
  }
}
