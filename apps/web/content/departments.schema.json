{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEC departments content",
  "description": "Per-department content keyed by the URL slug used in /programs/departments/<type>/<slug>. Only `name` is required; fill the rest as content arrives. Departments with just `name` + `assetSlug` still render (overview placeholder + photo gallery).",
  "type": "object",
  "required": [
    "departments"
  ],
  "additionalProperties": false,
  "$defs": {
    "codedItem": {
      "type": "object",
      "description": "A labelled statement, e.g. a PEO or PSO.",
      "required": [
        "code",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "description": "Short label, e.g. \"PSO1\"."
        },
        "text": {
          "type": "string"
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string"
    },
    "departments": {
      "type": "object",
      "description": "Map of URL slug -> department content.",
      "additionalProperties": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Full display name."
          },
          "tagline": {
            "type": "string",
            "description": "One-line subtitle shown under the page title."
          },
          "assetSlug": {
            "type": "string",
            "description": "R2 folder under departments/<assetSlug>/ whose photos build the Infrastructure gallery. Omit if no photos exist yet."
          },
          "heroImage": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Full-bleed hero image (asset key on R2) shown at the top of the department page, home-hero style."
          },
          "heroImages": {
            "type": "array",
            "description": "Rolling hero carousel (arrows + autoplay). When 2+ keys are given, renders instead of the single heroImage.",
            "items": {
              "allOf": [
                {
                  "$ref": "./_schema/asset-keys.json"
                }
              ]
            }
          },
          "mouImages": {
            "type": "array",
            "description": "MoU signing photos (asset keys) shown as a gallery under the MoUs section.",
            "items": {
              "allOf": [
                {
                  "$ref": "./_schema/asset-keys.json"
                }
              ]
            }
          },
          "researchGallery": {
            "type": "array",
            "description": "Research-laboratory photo galleries shown under the Research section.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["images"],
              "properties": {
                "title": { "type": "string" },
                "images": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "./_schema/asset-keys.json"
                      }
                    ]
                  }
                }
              }
            }
          },
          "infrastructureGallerySlug": {
            "type": "string",
            "description": "Explicit R2 folder under departments/<infrastructureGallerySlug>/ for verified infrastructure photos. Use this for PG departments instead of assetSlug fallback."
          },
          "established": {
            "type": "string",
            "description": "Year the department was established, e.g. \"1983\"."
          },
          "intake": {
            "type": "string",
            "description": "Sanctioned UG intake, e.g. \"180\"."
          },
          "nbaAccredited": {
            "type": "boolean",
            "description": "When true, surfaces an \"NBA Accredited\" card in the Home quick-stats row."
          },
          "overview": {
            "type": "string",
            "description": "Department overview paragraph (Home tab)."
          },
          "overviewImage": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Image asset key on R2 shown above the Home overview (e.g. the department group photo)."
          },
          "overviewImageCaption": {
            "type": "string",
            "description": "Caption rendered below the overview lead image (e.g. \"Teaching Faculty\")."
          },
          "facultyGroupPhoto": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Group photo of the teaching faculty, shown as a banner above the Faculty grid."
          },
          "facultyGroupPhotoCaption": {
            "type": "string",
            "description": "Highlighted caption rendered below the teaching-faculty group photo (e.g. \"Teaching Faculty\")."
          },
          "staffGroupPhoto": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Group photo of the supporting staff, shown as a banner above the Supporting Staff tables."
          },
          "staffGroupPhotoCaption": {
            "type": "string",
            "description": "Highlighted caption rendered below the supporting-staff group photo (e.g. \"Supporting Staff\")."
          },
          "placementsPhoto": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Group photo of placed students, shown as a captioned banner at the end of the Placements section."
          },
          "placementsPhotoCaption": {
            "type": "string",
            "description": "Highlighted caption rendered below the placements group photo (e.g. \"Placed Students 25-26\")."
          },
          "homeGroupPhoto": {
            "allOf": [
              {
                "$ref": "./_schema/asset-keys.json"
              }
            ],
            "description": "Group photo shown as a captioned banner at the very end of the department Home tab (e.g. the graduating batch)."
          },
          "homeGroupPhotoCaption": {
            "type": "string",
            "description": "Highlighted caption rendered below the Home-tab group photo (e.g. \"Graduating Batch 22-26\")."
          },
          "facilitiesGallery": {
            "type": "array",
            "description": "Categorised facility photos (classrooms, labs, library, campus), shown as captioned galleries on the Facilities tab.",
            "items": {
              "type": "object",
              "required": [
                "images"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string",
                  "description": "Caption for this group of photos (e.g. Classrooms, Library)."
                },
                "images": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "./_schema/asset-keys.json"
                      }
                    ]
                  }
                }
              }
            }
          },
          "galleryExclude": {
            "type": "array",
            "description": "Asset-key substrings to drop from the generic Infrastructure gallery (e.g. shots already placed under Research/Facilities).",
            "items": {
              "type": "string"
            }
          },
          "hodMessage": {
            "type": "object",
            "description": "Message from the Head of Department, shown on the Home tab.",
            "required": [
              "message"
            ],
            "additionalProperties": false,
            "properties": {
              "message": {
                "type": "string",
                "description": "The HOD's message body."
              },
              "name": {
                "type": "string",
                "description": "Name of the HOD (byline)."
              },
              "designation": {
                "type": "string",
                "description": "Designation of the HOD (byline)."
              },
              "image": {
                "allOf": [
                  {
                    "$ref": "./_schema/asset-keys.json"
                  }
                ],
                "description": "Image asset key on R2 for the HOD's photo."
              }
            }
          },
          "vision": {
            "type": "string",
            "description": "Vision statement (About tab)."
          },
          "mission": {
            "type": "array",
            "description": "Mission points (About tab), one per bullet.",
            "items": {
              "type": "string"
            }
          },
          "programsOffered": {
            "type": "array",
            "description": "Programs the department offers (B.E., M.Tech, Ph.D., ...).",
            "items": {
              "type": "string"
            }
          },
          "programsOfferedCount": {
            "type": "integer",
            "description": "Overrides the 'Programs Offered' stat count when bullets expand one programme into multiple recognition tracks. Defaults to programsOffered length."
          },
          "peos": {
            "type": "array",
            "description": "Programme Educational Objectives.",
            "items": {
              "$ref": "#/$defs/codedItem"
            }
          },
          "psos": {
            "type": "array",
            "description": "Programme Specific Outcomes.",
            "items": {
              "$ref": "#/$defs/codedItem"
            }
          },
          "highlights": {
            "type": "array",
            "description": "Short bullet highlights shown on the Home tab.",
            "items": {
              "type": "string"
            }
          },
          "milestones": {
            "type": "object",
            "description": "Department milestones, shown under Vision & Mission on the About tab.",
            "required": [
              "items"
            ],
            "additionalProperties": false,
            "properties": {
              "title": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "researchAreas": {
            "type": "array",
            "description": "Research supervisors and their areas of specialization.",
            "items": {
              "type": "object",
              "required": [
                "supervisor",
                "area"
              ],
              "additionalProperties": false,
              "properties": {
                "supervisor": {
                  "type": "string"
                },
                "area": {
                  "type": "string"
                },
                "university": {
                  "type": "string"
                }
              }
            }
          },
          "labs": {
            "type": "array",
            "description": "Research / specialized laboratories.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "features": {
                  "type": "array",
                  "description": "Feature/capability bullets rendered as a list under this lab on the Research tab.",
                  "items": {
                    "type": "string"
                  }
                },
                "images": {
                  "type": "array",
                  "description": "Photo asset keys on R2 for this lab, shown as a grid under it on the Research tab.",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "./_schema/asset-keys.json"
                      }
                    ]
                  }
                },
                "feature": {
                  "type": "boolean",
                  "description": "Render this lab's image(s) large (single column) instead of small grid tiles — for showcase labs like a Centre of Excellence."
                }
              }
            }
          },
          "achievementsUnderResearch": {
            "type": "boolean",
            "description": "When true, the Ph.D.s/Scholars/Grants tables render inside the Research tab and no standalone Research Achievements tab is shown."
          },
          "infrastructureLabs": {
            "type": "array",
            "description": "Labs shown under the Infrastructure tab (title + caption + images), separate from `labs` which render under Research.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "images": {
                  "type": "array",
                  "description": "Photo asset keys on R2 for this lab, shown as a grid under it on the Infrastructure tab.",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "./_schema/asset-keys.json"
                      }
                    ]
                  }
                }
              }
            }
          },
          "staffCards": {
            "type": "boolean",
            "description": "Render Supporting Staff as photo cards (like teaching faculty) instead of tables."
          },
          "facultyCompact": {
            "type": "boolean",
            "description": "Render faculty/staff cards in a compact layout with a small portrait instead of the full-width photo."
          },
          "supportingStaff": {
            "type": "array",
            "description": "Supporting staff records from legacy department pages.",
            "items": {
              "type": "object",
              "required": [
                "name",
                "designation"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "designation": {
                  "type": "string"
                },
                "photo": {
                  "allOf": [
                    {
                      "$ref": "./_schema/asset-keys.json"
                    }
                  ],
                  "description": "Portrait asset key on R2 (used when staffCards is enabled)."
                }
              }
            }
          },
          "committeeGroups": {
            "type": "array",
            "description": "Department board memberships such as BOS and BOE.",
            "items": {
              "type": "object",
              "required": [
                "title",
                "members"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string"
                },
                "members": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "position"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "position": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "infrastructureItems": {
            "type": "array",
            "description": "Major equipment rows from legacy infrastructure pages.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "specification": {
                  "type": "string"
                },
                "quantity": {
                  "type": "string"
                }
              }
            }
          },
          "softwareItems": {
            "type": "array",
            "description": "Software rows from legacy infrastructure pages.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "version": {
                  "type": "string"
                },
                "usage": {
                  "type": "string"
                }
              }
            }
          },
          "activities": {
            "type": "array",
            "description": "Recent events, workshops, talks and department activities.",
            "items": {
              "type": "object",
              "required": [
                "title"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string"
                },
                "date": {
                  "type": "string",
                  "description": "Free-text date, e.g. \"Mar 2025\"."
                },
                "description": {
                  "type": "string"
                },
                "details": {
                  "type": "array",
                  "description": "Labelled facts about the event (e.g. Resource person, Participants, Budget, Outcomes). Rendered as a bullet list under the description.",
                  "items": {
                    "type": "string"
                  }
                },
                "images": {
                  "type": "array",
                  "description": "Captioned event photos rendered as a gallery under the activity.",
                  "items": {
                    "type": "object",
                    "required": [
                      "key"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "key": {
                        "allOf": [
                          {
                            "$ref": "./_schema/asset-keys.json"
                          }
                        ]
                      },
                      "caption": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "activitiesUnderAssociation": {
            "type": "boolean",
            "description": "When true, the activities render at the end of the Association section and no standalone Activities tab is shown."
          },
          "activityTables": {
            "type": "array",
            "description": "Department activity programmes (SDPs, FDPs, workshops) rendered as titled tables under an \"Activities\" section.",
            "items": {
              "type": "object",
              "required": [
                "title",
                "columns",
                "rows"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string"
                },
                "columns": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "rows": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "associations": {
            "type": "array",
            "description": "Student forums / professional associations run by the department.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "about": {
                  "type": "string"
                },
                "photo": {
                  "allOf": [
                    {
                      "$ref": "./_schema/asset-keys.json"
                    }
                  ],
                  "description": "Group photo of the association's office bearers, shown as a captioned banner at the end of the section."
                },
                "photoCaption": {
                  "type": "string",
                  "description": "Highlighted caption rendered below the association photo (e.g. \"ACME Office Bearers\")."
                },
                "coordinators": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "exicom": {
                  "type": "array",
                  "description": "Student executive committee (exicom) office bearers.",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "position"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "position": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "contact": {
            "type": "object",
            "description": "Head of Department / department contact shown on the page.",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "designation": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "photo": {
                "type": "string",
                "description": "Asset key for the contact's photo, shown alongside their details."
              }
            }
          },
          "additionalContacts": {
            "type": "array",
            "description": "Additional department contact people shown on legacy pages.",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string"
                },
                "designation": {
                  "type": "string"
                },
                "phone": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                }
              }
            }
          },
          "documents": {
            "type": "array",
            "description": "Curriculum / syllabus PDFs (Scheme & Syllabus, BoS, course plans). Rendered as the 'Curriculum' download section.",
            "items": {
              "type": "object",
              "required": [
                "title",
                "file"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string"
                },
                "file": {
                  "allOf": [
                    {
                      "$ref": "./_schema/asset-keys.json"
                    }
                  ],
                  "description": "PDF asset key on R2 (autocompletes)."
                }
              }
            }
          },
          "customSections": {
            "type": "array",
            "description": "Free-form extra sections, each its own sidebar tab: intro copy plus inline-embedded PDFs and/or download links (e.g. 'Life at DOMS').",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title"
              ],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Unique section/tab id (kebab-case)."
                },
                "title": {
                  "type": "string"
                },
                "label": {
                  "type": "string",
                  "description": "Sidebar label; falls back to title."
                },
                "icon": {
                  "type": "string",
                  "description": "Section/sidebar icon key (e.g. calendar, image, users)."
                },
                "content": {
                  "type": "string"
                },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "embeds": {
                  "type": "array",
                  "description": "PDFs rendered inline in a viewer.",
                  "items": {
                    "type": "object",
                    "required": [
                      "title",
                      "file"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "title": {
                        "type": "string"
                      },
                      "file": {
                        "allOf": [
                          {
                            "$ref": "./_schema/asset-keys.json"
                          }
                        ],
                        "description": "PDF asset key on R2 (autocompletes)."
                      }
                    }
                  }
                },
                "documents": {
                  "type": "array",
                  "description": "PDFs rendered as download links.",
                  "items": {
                    "type": "object",
                    "required": [
                      "title",
                      "file"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "title": {
                        "type": "string"
                      },
                      "file": {
                        "allOf": [
                          {
                            "$ref": "./_schema/asset-keys.json"
                          }
                        ],
                        "description": "PDF asset key on R2 (autocompletes)."
                      }
                    }
                  }
                }
              }
            }
          },
          "alumniRecords": {
            "type": "array",
            "description": "Alumni record PDFs. Rendered as a downloadable 'Alumni Records' section.",
            "items": {
              "type": "object",
              "required": [
                "title",
                "file"
              ],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string"
                },
                "file": {
                  "allOf": [
                    {
                      "$ref": "./_schema/asset-keys.json"
                    }
                  ],
                  "description": "PDF asset key on R2 (autocompletes)."
                }
              }
            }
          }
        }
      }
    }
  }
}
