{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEC departments content",
  "description": "Per-department content keyed by the URL slug used in /programs/departments/<type>/<slug>. Only `name` is required; fill the rest as content arrives. Departments with just `name` + `assetSlug` still render (overview placeholder + photo gallery).",
  "type": "object",
  "required": ["departments"],
  "additionalProperties": false,
  "$defs": {
    "codedItem": {
      "type": "object",
      "description": "A labelled statement, e.g. a PEO or PSO.",
      "required": ["code", "text"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "description": "Short label, e.g. \"PSO1\"." },
        "text": { "type": "string" }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "departments": {
      "type": "object",
      "description": "Map of URL slug -> department content.",
      "additionalProperties": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "description": "Full display name." },
          "tagline": { "type": "string", "description": "One-line subtitle shown under the page title." },
          "assetSlug": {
            "type": "string",
            "description": "R2 folder under departments/<assetSlug>/ whose photos build the Infrastructure gallery. Omit if no photos exist yet."
          },
          "infrastructureGallerySlug": {
            "type": "string",
            "description": "Explicit R2 folder under departments/<infrastructureGallerySlug>/ for verified infrastructure photos. Use this for PG departments instead of assetSlug fallback."
          },
          "established": { "type": "string", "description": "Year the department was established, e.g. \"1983\"." },
          "intake": { "type": "string", "description": "Sanctioned UG intake, e.g. \"180\"." },
          "overview": { "type": "string", "description": "Department overview paragraph (Home tab)." },
          "overviewImage": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "Image asset key on R2 shown above the Home overview (e.g. the department group photo)." },
          "facultyGroupPhoto": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "Group photo of the teaching faculty, shown as a banner above the Faculty grid." },
          "staffGroupPhoto": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "Group photo of the supporting staff, shown as a banner above the Supporting Staff tables." },
          "facilitiesGallery": {
            "type": "array",
            "description": "Categorised facility photos (classrooms, labs, library, campus), shown as captioned galleries on the Facilities tab.",
            "items": {
              "type": "object",
              "required": ["images"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string", "description": "Caption for this group of photos (e.g. Classrooms, Library)." },
                "images": {
                  "type": "array",
                  "items": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }] }
                }
              }
            }
          },
          "galleryExclude": {
            "type": "array",
            "description": "Asset-key substrings to drop from the generic Infrastructure gallery (e.g. shots already placed under Research/Facilities).",
            "items": { "type": "string" }
          },
          "hodMessage": {
            "type": "object",
            "description": "Message from the Head of Department, shown on the Home tab.",
            "required": ["message"],
            "additionalProperties": false,
            "properties": {
              "message": { "type": "string", "description": "The HOD's message body." },
              "name": { "type": "string", "description": "Name of the HOD (byline)." },
              "designation": { "type": "string", "description": "Designation of the HOD (byline)." },
              "image": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "Image asset key on R2 for the HOD's photo." }
            }
          },
          "vision": { "type": "string", "description": "Vision statement (About tab)." },
          "mission": {
            "type": "array",
            "description": "Mission points (About tab), one per bullet.",
            "items": { "type": "string" }
          },
          "programsOffered": {
            "type": "array",
            "description": "Programs the department offers (B.E., M.Tech, Ph.D., ...).",
            "items": { "type": "string" }
          },
          "peos": {
            "type": "array",
            "description": "Programme Educational Objectives.",
            "items": { "$ref": "#/$defs/codedItem" }
          },
          "psos": {
            "type": "array",
            "description": "Programme Specific Outcomes.",
            "items": { "$ref": "#/$defs/codedItem" }
          },
          "highlights": {
            "type": "array",
            "description": "Short bullet highlights shown on the Home tab.",
            "items": { "type": "string" }
          },
          "researchAreas": {
            "type": "array",
            "description": "Research supervisors and their areas of specialization.",
            "items": {
              "type": "object",
              "required": ["supervisor", "area"],
              "additionalProperties": false,
              "properties": {
                "supervisor": { "type": "string" },
                "area": { "type": "string" },
                "university": { "type": "string" }
              }
            }
          },
          "labs": {
            "type": "array",
            "description": "Research / specialized laboratories.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "images": {
                  "type": "array",
                  "description": "Photo asset keys on R2 for this lab, shown as a grid under it on the Research & Labs tab.",
                  "items": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }] }
                }
              }
            }
          },
          "supportingStaff": {
            "type": "array",
            "description": "Supporting staff records from legacy department pages.",
            "items": {
              "type": "object",
              "required": ["name", "designation"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "designation": { "type": "string" }
              }
            }
          },
          "committeeGroups": {
            "type": "array",
            "description": "Department board memberships such as BOS and BOE.",
            "items": {
              "type": "object",
              "required": ["title", "members"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string" },
                "members": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "position"],
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string" },
                      "position": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "infrastructureItems": {
            "type": "array",
            "description": "Major equipment rows from legacy infrastructure pages.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "specification": { "type": "string" },
                "quantity": { "type": "string" }
              }
            }
          },
          "softwareItems": {
            "type": "array",
            "description": "Software rows from legacy infrastructure pages.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "version": { "type": "string" },
                "usage": { "type": "string" }
              }
            }
          },
          "activities": {
            "type": "array",
            "description": "Recent events, workshops, talks and department activities.",
            "items": {
              "type": "object",
              "required": ["title"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string" },
                "date": { "type": "string", "description": "Free-text date, e.g. \"Mar 2025\"." },
                "description": { "type": "string" }
              }
            }
          },
          "associations": {
            "type": "array",
            "description": "Student forums / professional associations run by the department.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "about": { "type": "string" },
                "coordinators": { "type": "array", "items": { "type": "string" } },
                "exicom": {
                  "type": "array",
                  "description": "Student executive committee (exicom) office bearers.",
                  "items": {
                    "type": "object",
                    "required": ["name", "position"],
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string" },
                      "position": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "contact": {
            "type": "object",
            "description": "Head of Department / department contact shown on the page.",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "designation": { "type": "string" },
              "phone": { "type": "string" },
              "email": { "type": "string" }
            }
          },
          "additionalContacts": {
            "type": "array",
            "description": "Additional department contact people shown on legacy pages.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "designation": { "type": "string" },
                "phone": { "type": "string" },
                "email": { "type": "string" }
              }
            }
          },
          "documents": {
            "type": "array",
            "description": "Curriculum / syllabus PDFs (Scheme & Syllabus, BoS, course plans). Rendered as the 'Curriculum & Syllabus' download section.",
            "items": {
              "type": "object",
              "required": ["title", "file"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string" },
                "file": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "PDF asset key on R2 (autocompletes)." }
              }
            }
          },
          "alumniRecords": {
            "type": "array",
            "description": "Alumni record PDFs. Rendered as a downloadable 'Alumni Records' section.",
            "items": {
              "type": "object",
              "required": ["title", "file"],
              "additionalProperties": false,
              "properties": {
                "title": { "type": "string" },
                "file": { "allOf": [{ "$ref": "./_schema/asset-keys.json" }], "description": "PDF asset key on R2 (autocompletes)." }
              }
            }
          }
        }
      }
    }
  }
}
