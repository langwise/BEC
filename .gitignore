# Corrections tracking workspace — ledger, dashboard, scripts. Local-only,
# not part of the shipped site. Kept on disk but never committed.
/corrections/

# Local source data — scraped site mirror + provided department docs/images.
# These are the raw inputs (GBs of binaries); images/PDFs are uploaded to R2 and
# referenced via asset(). Nothing under here should ever be committed.
/data/
/optimized-and-html/

# Asset-pipeline staging folders — optimized images live on R2, not in git.
# (e.g. temp-library-staff-r2/ that leaked once.) Never commit these.
apps/web/temp-*/

.claude/workflows/